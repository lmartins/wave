# Wave release credential template.
# Copy to $HOME/.pi/agent/wave-release.env (or set WAVE_RELEASE_ENV) or a secure location.
# Do not commit real values.
# Source via: source scripts/release/load-release-env.sh

# Cloudflare R2 / S3-compatible release artifact publishing (for appcast.xml + DMGs)
export R2_BUCKET="wave-updates"
export R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
export AWS_ACCESS_KEY_ID="<r2-access-key-id>"
export AWS_SECRET_ACCESS_KEY="<r2-secret-access-key>"

# Public update URLs (configure custom domain on Cloudflare to point at the R2 bucket)
export APPCAST_URL="https://updates.wave.mxv.sh/appcast.xml"
export DMG_URL="https://updates.wave.mxv.sh/downloads/Wave-latest.dmg"

# Stable human-facing and Sparkle enclosure URL. publish-r2.sh overwrites the -latest on each release.
export LATEST_DMG_URL="https://updates.wave.mxv.sh/downloads/Wave-latest.dmg"

# Optional: main site / verification
export APP_URL="https://wave.mxv.sh"
# export SENTRY_TEST_TOKEN=...  # if using for verification

# Notary profile name (created once with xcrun notarytool store-credentials)
export NOTARY_PROFILE="wave-notary"
